# ============================================
# Node.js
# ============================================
node_modules/
*/node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Mixmlaal prefixed node_modules (due to Windows path limits)
**/mixmlaal-node_modules/

# Nested Git repositories
**/.git/
**/mixmlaal-.git/

# ============================================
# 环境变量
# ============================================
.env
.env.local
.env.*.local

# ============================================
# 构建输出
# ============================================
dist/
build/
.next/
.nuxt/
.cache/

# ============================================
# 日志文件
# ============================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# IDE 和编辑器
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# 数据库
# ============================================
*.sqlite
*.db
dump.sql

# ============================================
# 临时文件
# ============================================
*.tmp
*.temp
tmp/
temp/

# ============================================
# 测试覆盖率
# ============================================
coverage/
.nyc_output/

# ============================================
# 类型声明缓存
# ============================================
*.tsbuildinfo

# ============================================
# 操作系统文件
# ============================================
Thumbs.db
.DS_Store

# ============================================
# 大文件
# ============================================
*.zip
*.tar
*.tar.gz
*.rar

# 备份文件和临时Git仓库
**/*backup/
**/*.backup
**/mixmlaal-.git.backup/
