# ============================================
# MIXMLAAL 项目环境变量配置模板
# 复制此文件为 .env 并根据需要修改配置
# ============================================

# ============================================
# 服务器配置
# ============================================
PORT=3000
NODE_ENV=development
API_PREFIX=/api/v1

# ============================================
# MySQL 数据库配置
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=mixmlaal

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# MongoDB 配置 (可选)
# ============================================
MONGO_URI=mongodb://localhost:27017/mixmlaal

# ============================================
# JWT 安全配置
# ============================================
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# 安全配置
# ============================================
CORS_ORIGIN=*
CSRF_SECRET=your_csrf_secret_key
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_MAX_SIZE=50m
LOG_MAX_FILES=5

# ============================================
# 应用信息
# ============================================
APP_NAME=MIXMLAAL
APP_VERSION=0.0.0.4
APP_DESCRIPTION=全球卓越的一站式多元化出行+本地生活生态平台

# ============================================
# 默认管理员账号
# ============================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# ============================================
# 第三方服务配置 (按需配置)
# ============================================

# 短信服务
SMS_API_KEY=your_sms_api_key
SMS_SIGN=MIXMLAAL

# 邮件服务
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password
EMAIL_FROM=noreply@example.com

# 支付服务
WECHAT_APP_ID=your_wechat_app_id
WECHAT_MCH_ID=your_wechat_mch_id
ALIPAY_APP_ID=your_alipay_app_id

# 云存储
CLOUD_STORAGE_ACCESS_KEY=your_access_key
CLOUD_STORAGE_SECRET_KEY=your_secret_key
CLOUD_STORAGE_BUCKET=mixmlaal-files

# ============================================
# 监控配置
# ============================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
