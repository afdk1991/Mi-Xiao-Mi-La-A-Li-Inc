# ============================================
# React 管理后台 - 环境变量配置模板
# ============================================
VITE_APP_NAME=管理后台
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# API 地址
VITE_API_BASE_URL=http://localhost:8080/api/v1

# 超时配置
VITE_API_TIMEOUT=15000

# 安全配置
VITE_USE_HTTPS=false

# 调试配置
VITE_ENABLE_DEBUG=true
VITE_SHOW_CONSOLE=true
