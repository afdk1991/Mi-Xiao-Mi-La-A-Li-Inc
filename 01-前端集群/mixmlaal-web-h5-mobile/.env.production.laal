# ============================================
# H5 移动端 - laal.top 生产环境配置
# ============================================
VITE_APP_NAME=H5移动端
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production

# API 地址
VITE_API_BASE_URL=https://laal.top/api/v1

# 超时配置
VITE_API_TIMEOUT=15000

# 安全配置
VITE_USE_HTTPS=true

# 调试配置
VITE_ENABLE_DEBUG=false
VITE_SHOW_CONSOLE=false
