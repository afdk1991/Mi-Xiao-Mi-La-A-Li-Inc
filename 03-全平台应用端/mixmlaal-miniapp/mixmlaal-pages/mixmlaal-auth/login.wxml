<view class="auth-container">
  <view class="auth-header">
    <text class="header-title">用户登录</text>
    <text class="header-subtitle">欢迎使用亿级商城</text>
  </view>

  <view class="auth-tabs">
    <view class="tab-item {{activeTab === 'account' ? 'active' : ''}}" bindtap="switchTab" data-tab="account">账号</view>
    <view class="tab-item {{activeTab === 'phone' ? 'active' : ''}}" bindtap="switchTab" data-tab="phone">手机</view>
    <view class="tab-item {{activeTab === 'email' ? 'active' : ''}}" bindtap="switchTab" data-tab="email">邮箱</view>
  </view>

  <view class="auth-form">
    <view class="form-item" wx:if="{{activeTab === 'account'}}">
      <input class="form-input" type="text" placeholder="请输入账号" value="{{account}}" bindinput="onInput" data-field="account" />
    </view>
    <view class="form-item" wx:if="{{activeTab === 'account'}}">
      <input class="form-input" type="password" placeholder="请输入密码" value="{{password}}" bindinput="onInput" data-field="password" />
    </view>

    <view class="form-item" wx:if="{{activeTab === 'phone'}}">
      <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onInput" data-field="phone" />
    </view>
    <view class="form-item code-item" wx:if="{{activeTab === 'phone'}}">
      <input class="form-input code-input" type="number" maxlength="6" placeholder="请输入验证码" value="{{code}}" bindinput="onInput" data-field="code" />
      <button class="code-btn" bindtap="sendCode" disabled="{{codeCountdown > 0}}">{{codeCountdown > 0 ? codeCountdown + 's' : '获取验证码'}}</button>
    </view>

    <view class="form-item" wx:if="{{activeTab === 'email'}}">
      <input class="form-input" type="email" placeholder="请输入邮箱" value="{{email}}" bindinput="onInput" data-field="email" />
    </view>
    <view class="form-item code-item" wx:if="{{activeTab === 'email'}}">
      <input class="form-input code-input" type="number" maxlength="6" placeholder="请输入验证码" value="{{code}}" bindinput="onInput" data-field="code" />
      <button class="code-btn" bindtap="sendCode" disabled="{{codeCountdown > 0}}">{{codeCountdown > 0 ? codeCountdown + 's' : '获取验证码'}}</button>
    </view>

    <view class="error-msg" wx:if="{{errorMsg}}">{{errorMsg}}</view>

    <button class="submit-btn" bindtap="handleLogin" loading="{{loading}}">登录</button>

    <view class="third-party-section">
      <view class="section-title">
        <view class="title-line"></view>
        <text class="title-text">其他登录方式</text>
        <view class="title-line"></view>
      </view>
      <view class="third-party-btns">
        <button class="third-party-btn wechat" bindtap="thirdPartyLogin" data-platform="wechat">
          <text class="btn-icon">微</text>
        </button>
        <button class="third-party-btn qq" bindtap="thirdPartyLogin" data-platform="qq">
          <text class="btn-icon">Q</text>
        </button>
        <button class="third-party-btn weibo" bindtap="thirdPartyLogin" data-platform="weibo">
          <text class="btn-icon">微</text>
        </button>
        <button class="third-party-btn alipay" bindtap="thirdPartyLogin" data-platform="alipay">
          <text class="btn-icon">支</text>
        </button>
      </view>
    </view>

    <view class="auth-footer">
      <text class="footer-text">还没有账号？</text>
      <navigator url="/pages/auth/register" class="footer-link">立即注册</navigator>
    </view>
  </view>
</view>
