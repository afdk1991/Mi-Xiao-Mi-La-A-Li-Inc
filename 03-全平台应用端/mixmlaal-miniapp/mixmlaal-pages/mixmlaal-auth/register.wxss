.auth-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
}

.auth-header {
  text-align: center;
  padding: 60rpx 0;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.auth-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 40rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: #667eea;
  color: #fff;
  font-weight: bold;
}

.auth-form {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #667eea;
}

.code-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.code-input {
  flex: 1;
}

.code-btn {
  width: 200rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #667eea;
  color: #fff;
  font-size: 24rpx;
  border-radius: 12rpx;
  padding: 0;
  margin: 0;
}

.code-btn[disabled] {
  background: #ccc;
}

.agreement-item {
  margin-bottom: 30rpx;
}

.agreement-label {
  display: flex;
  align-items: center;
  font-size: 24rpx;
}

.agreement-text {
  color: #666;
  margin-left: 10rpx;
}

.agreement-link {
  color: #667eea;
}

.error-msg {
  background: #fef0f0;
  border: 2rpx solid #fde2e2;
  color: #f56c6c;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  font-size: 24rpx;
  text-align: center;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  margin-bottom: 40rpx;
}

.auth-footer {
  display: flex;
  justify-content: center;
  align-items: center;
}

.footer-text {
  font-size: 26rpx;
  color: #666;
}

.footer-link {
  font-size: 26rpx;
  color: #667eea;
  margin-left: 10rpx;
}
